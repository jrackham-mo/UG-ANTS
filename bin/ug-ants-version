"""
Check whether UG_ANTS and Iris can be imported.

If they can, the file and version number is printed so that the build which has
been loaded can be checked. This is designed to be called from inside
ug-ants-launch.
"""

import iris
import ugants

print("[INFO] UG_ANTS version loaded was:")
print(f"ugants: {ugants.__file__} (version {ugants.__version__})")

print("[INFO] Iris version loaded was:")
print(f"iris: {iris.__file__} (version {iris.__version__})")
